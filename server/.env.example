# PostgreSQL (default)
DATABASE_URL="postgresql://quizuser:password@localhost:5432/quizapp"

# MySQL — swap provider in prisma/schema.prisma to "mysql" and use this instead:
# DATABASE_URL="mysql://quizuser:password@localhost:3306/quizapp"

PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Generate a strong random string for production: openssl rand -hex 64
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

NODE_ENV=development
